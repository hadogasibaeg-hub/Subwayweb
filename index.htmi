<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>수도권 광역 전철망 (데이터 내장형)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700;900&display=swap');
        
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #0f172a;
            color: #f1f5f9;
            margin: 0;
            overflow: hidden;
            touch-action: none;
            user-select: none;
        }

        .main-layout {
            display: flex;
            height: 100vh;
            width: 100vw;
            position: relative;
            overflow: hidden;
        }

        .map-viewport {
            flex-grow: 1;
            position: relative;
            background: #0b1120;
            overflow: hidden;
            cursor: grab;
        }

        .map-viewport:active { cursor: grabbing; }

        .subway-canvas {
            position: absolute;
            width: 6000px;
            height: 6000px;
            background: #0b1120;
            transform-origin: 0 0;
            will-change: transform;
        }

        #svg-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .river-path {
            fill: none;
            stroke: #1e3a8a;
            stroke-width: 200;
            opacity: 0.15;
            stroke-linecap: round;
            stroke-linejoin: round;
            filter: blur(10px);
        }

        .subway-path {
            fill: none;
            stroke-width: 12;
            stroke-linecap: round;
            stroke-linejoin: round;
            opacity: 0.8;
            transition: opacity 0.3s;
        }

        .station {
            position: absolute;
            width: 16px;
            height: 16px;
            background: #fff;
            border: 3px solid #0f172a;
            border-radius: 50%;
            cursor: pointer;
            z-index: 10;
            transform: translate(-50%, -50%);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .station-label {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            white-space: nowrap;
            font-size: 13px;
            font-weight: 700;
            color: #cbd5e1;
            pointer-events: none;
            text-shadow: 0px 2px 4px rgba(0,0,0,0.9);
        }

        .station.transfer {
            width: 26px;
            height: 26px;
            border-width: 5px;
            z-index: 20;
        }

        .station.active {
            box-shadow: 0 0 0 12px rgba(255, 255, 255, 0.25);
            border-color: #fff !important;
            transform: translate(-50%, -50%) scale(1.3);
            z-index: 150;
        }

        .info-sidebar {
            width: 400px;
            min-width: 400px;
            background: rgba(15, 23, 42, 0.98);
            backdrop-filter: blur(25px);
            border-left: 1px solid #1e293b;
            padding: 2.5rem;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .info-sidebar.collapsed { transform: translateX(100%); position: absolute; right: 0; height: 100%; }

        .toggle-handle {
            position: absolute;
            top: 25px;
            right: 420px;
            z-index: 1100;
            transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .info-sidebar.collapsed + .toggle-handle { right: 25px; }

        .toggle-btn {
            background: #3b82f6;
            color: white;
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 16px rgba(59, 130, 246, 0.4);
            cursor: pointer;
        }

        .zoom-controls {
            position: absolute;
            bottom: 40px;
            left: 40px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 500;
        }

        .zoom-btn {
            width: 56px;
            height: 56px;
            background: rgba(30, 41, 59, 0.95);
            border: 1px solid #475569;
            border-radius: 16px;
            color: white;
            font-size: 1.6rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .line-badge {
            padding: 4px 14px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 800;
            color: white;
            margin: 0 8px 8px 0;
            display: inline-block;
        }

        .search-input {
            width: 100%;
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 16px 20px;
            color: white;
            font-size: 16px;
            outline: none;
        }

        .loader {
            width: 20px;
            height: 20px;
            border: 3px solid #3b82f6;
            border-bottom-color: transparent;
            border-radius: 50%;
            display: inline-block;
            animation: rotation 1s linear infinite;
        }
        @keyframes rotation { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        .ai-content {
            font-size: 0.95rem;
            line-height: 1.7;
            color: #cbd5e1;
        }
        
        .ai-content h3 {
            color: #3b82f6;
            font-weight: 800;
            margin-top: 1.5rem;
            margin-bottom: 0.5rem;
            font-size: 1.1rem;
        }
        
        .ai-content li {
            margin-bottom: 0.5rem;
            position: relative;
            padding-left: 1.2rem;
        }
        
        .ai-content li::before {
            content: "•";
            position: absolute;
            left: 0;
            color: #3b82f6;
        }
    </style>
</head>
<body>

    <div class="main-layout">
        <div class="map-viewport" id="viewport">
            <div class="zoom-controls">
                <button id="zoom-in" class="zoom-btn" title="확대">+</button>
                <button id="zoom-out" class="zoom-btn" title="축소">-</button>
                <button id="zoom-reset" class="zoom-btn" title="초기화">⟲</button>
            </div>

            <div class="subway-canvas" id="canvas">
                <svg id="svg-layer" width="6000" height="6000">
                    <path class="river-path" d="M -500 3500 C 500 3550, 1500 3350, 2500 3500 C 3500 3650, 4500 3450, 6500 3500" />
                </svg>
            </div>
        </div>

        <aside class="info-sidebar" id="sidebar">
            <div class="search-container relative mb-10">
                <input type="text" id="station-search" class="search-input" placeholder="역 검색 (예: 서울역, 강남)...">
                <div id="search-results" class="search-results absolute top-full left-0 right-0 bg-slate-800 border border-slate-700 rounded-2xl mt-2 max-h-60 overflow-y-auto hidden z-[2000]"></div>
            </div>

            <div id="welcome-view">
                <h1 class="text-3xl font-black mb-2 text-white tracking-tighter">수도권 전철망 가이드</h1>
                <p class="text-blue-400 text-sm mb-8 font-bold">네트워크 연결 없이도 정보를 바로 확인하세요</p>
                
                <div class="bg-slate-900/50 p-6 rounded-3xl border border-slate-800">
                    <h3 class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-4">주요 운행 노선</h3>
                    <div id="legend" class="grid grid-cols-2 gap-y-3 text-sm"></div>
                </div>
            </div>

            <div id="detail-view" class="hidden h-full flex flex-col">
                <div id="line-badges" class="flex flex-wrap mb-4"></div>
                <h2 id="st-name" class="text-4xl font-black text-white mb-6 tracking-tight"></h2>
                <div class="bg-slate-800/40 rounded-3xl p-6 flex-grow overflow-y-auto border border-white/5">
                    <div id="ai-response-container">
                        <div id="loading-spinner" class="hidden items-center gap-3 text-blue-400 font-bold mb-4">
                            <span class="loader"></span> 정보를 불러오는 중...
                        </div>
                        <div id="ai-response" class="ai-content"></div>
                    </div>
                </div>
                <button onclick="closeDetail()" class="w-full py-5 mt-6 bg-slate-700 text-white rounded-2xl font-bold hover:bg-slate-600 transition-colors">닫기</button>
            </div>
        </aside>

        <div class="toggle-handle" id="toggle-handle">
            <div class="toggle-btn" onclick="toggleSidebar()"><span id="toggle-icon">➔</span></div>
        </div>
    </div>

    <script>
        // 내장된 역별 가이드 데이터 (네트워크 독립형)
        const stationGuides = {
            "서울역": {
                desc: "대한민국 철도 교통의 중심지로, 1호선, 4호선, 경의중앙선, 공항철도, KTX가 만나는 초대형 거점입니다.",
                spots: ["서울로 7017 (산책길)", "문화역서울 284", "롯데몰 광장"]
            },
            "강남": {
                desc: "2호선과 신분당선이 만나는 서울 최고의 상업 지구입니다. 하루 이용객이 가장 많은 역 중 하나입니다.",
                spots: ["강남역 지하상가", "강남대로 카페거리", "카카오프렌즈 플래그십스토어"]
            },
            "홍대입구": {
                desc: "젊음과 예술의 거리로 유명하며, 공항철도와의 연계로 외국인 관광객이 가장 많이 찾는 지역입니다.",
                spots: ["홍대 걷고싶은거리", "경의선 숲길", "연남동 맛집거리"]
            },
            "잠실": {
                desc: "2호선과 8호선 환승역으로, 롯데월드타워와 석촌호수가 위치한 송파구의 핵심 교통 요지입니다.",
                spots: ["롯데월드 타워 & 몰", "석촌호수", "송리단길"]
            },
            "고속터미널": {
                desc: "3, 7, 9호선이 만나는 '트리플 역세권'으로 전국으로 연결되는 버스 터미널과 신세계백화점이 직결되어 있습니다.",
                spots: ["고투몰 (지하쇼핑몰)", "반포 한강공원", "파미에스테이션"]
            },
            "여의도": {
                desc: "정치, 금융의 중심지이자 여의도 한강공원과 IFC몰, 더현대 서울이 위치한 복합 문화 지구입니다.",
                spots: ["더현대 서울", "IFC몰", "여의도 한강공원"]
            },
            "시청": {
                desc: "1호선과 2호선이 교차하며 서울시청, 덕수궁 등 역사적 명소가 인접한 행정의 중심지입니다.",
                spots: ["덕수궁 돌담길", "서울광장", "시립미술관"]
            },
            "종로3가": {
                desc: "1, 3, 5호선이 만나는 거대 환승역으로 익선동 한옥거리와 귀금속 거리가 유명합니다.",
                spots: ["익선동 한옥거리", "피맛골", "탑골공원"]
            },
            "수원": {
                desc: "경기도 남부의 관문으로 1호선, 수인분당선, KTX가 정차하는 교통의 핵심입니다.",
                spots: ["수원 화성행궁", "수원역 로데오거리", "방화수류정"]
            }
        };

        const subwayData = {
            lines: {
                "1": { name: "1호선", color: "#0052A4", sequence: ["소요산", "의정부", "도봉산", "창동", "회기", "청량리", "동묘앞", "종로3가", "시청", "서울역", "남영", "용산", "노량진", "신도림", "구로", "부평", "인천"] },
                "2": { name: "2호선", color: "#00A84D", sequence: ["시청", "을지로3가", "왕십리", "건대입구", "잠실", "종합운동장", "삼성", "강남", "교대", "사당", "신림", "신도림", "당산", "홍대입구", "신촌", "시청"] },
                "3": { name: "3호선", color: "#EF7C1C", sequence: ["대화", "대곡", "연신내", "경복궁", "종로3가", "을지로3가", "약수", "옥수", "압구정", "고속터미널", "교대", "양재", "수서", "오금"] },
                "4": { name: "4호선", color: "#00A5DE", sequence: ["진접", "불암산", "창동", "혜화", "서울역", "이촌", "동작", "사당", "금정", "안산", "오이도"] },
                "5": { name: "5호선", color: "#996CAC", sequence: ["방화", "김포공항", "여의도", "공덕", "광화문", "종로3가", "왕십리", "군자", "천호", "강동", "하남검단산"] },
                "6": { name: "6호선", color: "#CD7C2F", sequence: ["응암", "불광", "연신내", "디지털미디어시티", "합정", "공덕", "효창공원앞", "삼각지", "이태원", "약수", "동묘앞", "고려대", "석계", "태릉입구", "봉화산", "신내"] },
                "7": { name: "7호선", color: "#747F00", sequence: ["장암", "도봉산", "노원", "태릉입구", "상봉", "건대입구", "강남구청", "논현", "고속터미널", "이수", "대림", "온수", "부평구청", "석남"] },
                "8": { name: "8호선", color: "#E6186C", sequence: ["별내", "구리", "암사", "천호", "강동구청", "몽촌토성", "잠실", "석촌", "가락시장", "복정", "남한산성입구", "모란"] },
                "9": { name: "9호선", color: "#BDB092", sequence: ["개화", "김포공항", "마곡나루", "당산", "여의도", "노량진", "동작", "고속터미널", "선정릉", "종합운동장", "석촌", "올림픽공원", "중앙보훈병원"] },
                "K-J": { name: "경의중앙", color: "#77C4A3", sequence: ["문산", "일산", "대곡", "디지털미디어시티", "홍대입구", "공덕", "용산", "이촌", "옥수", "왕십리", "청량리", "회기", "상봉", "구리", "지평"] },
                "S-B": { name: "수인분당", color: "#F5A200", sequence: ["청량리", "왕십리", "선정릉", "강남구청", "선릉", "도곡", "수서", "복정", "모란", "서현", "기흥", "수원", "고색", "오이도", "인천"] },
                "S-X": { name: "신분당", color: "#D4003B", sequence: ["신사", "논현", "신논현", "강남", "양재", "판교", "정자", "광교"] }
            },
            stations: {
                "소요산": { x: 3200, y: 500, lines: ["1"], terminal: true },
                "서울역": { x: 2300, y: 2400, lines: ["1", "4"] },
                "강남": { x: 3100, y: 3400, lines: ["2", "S-X"] },
                "홍대입구": { x: 1800, y: 2400, lines: ["2", "K-J"] },
                "불암산": { x: 3400, y: 1100, lines: ["4"] },
                "종로3가": { x: 2500, y: 2100, lines: ["1", "3", "5"] },
                "왕십리": { x: 3100, y: 2300, lines: ["2", "5", "K-J", "S-B"] },
                "고속터미널": { x: 2900, y: 3200, lines: ["3", "7", "9"] },
                "의정부": { x: 3000, y: 800, lines: ["1"] },
                "도봉산": { x: 3000, y: 1100, lines: ["1", "7"] },
                "창동": { x: 3000, y: 1300, lines: ["1", "4"] },
                "노원": { x: 3200, y: 1300, lines: ["4", "7"] },
                "회기": { x: 3200, y: 1900, lines: ["1", "K-J"] },
                "청량리": { x: 3000, y: 2000, lines: ["1", "K-J", "S-B"] },
                "동묘앞": { x: 2700, y: 2100, lines: ["1", "6"] },
                "남영": { x: 2200, y: 2550, lines: ["1"] },
                "용산": { x: 2100, y: 2700, lines: ["1", "K-J"] },
                "노량진": { x: 2100, y: 3100, lines: ["1", "9"] },
                "신도림": { x: 1800, y: 3300, lines: ["1", "2"] },
                "구로": { x: 1600, y: 3300, lines: ["1"] },
                "부평": { x: 1000, y: 3300, lines: ["1"] },
                "인천": { x: 500, y: 3300, lines: ["1", "S-B"], terminal: true },
                "을지로3가": { x: 2700, y: 2200, lines: ["2", "3"] },
                "건대입구": { x: 3500, y: 2400, lines: ["2", "7"] },
                "잠실": { x: 3800, y: 2800, lines: ["2", "8"] },
                "종합운동장": { x: 3600, y: 3100, lines: ["2", "9"] },
                "삼성": { x: 3400, y: 3300, lines: ["2"] },
                "교대": { x: 2900, y: 3400, lines: ["2", "3"] },
                "사당": { x: 2500, y: 3600, lines: ["2", "4"] },
                "신림": { x: 2100, y: 3500, lines: ["2"] },
                "당산": { x: 1800, y: 2800, lines: ["2", "9"] },
                "신촌": { x: 2000, y: 2300, lines: ["2"] },
                "대화": { x: 1000, y: 1500, lines: ["3"], terminal: true },
                "대곡": { x: 1500, y: 1600, lines: ["3", "K-J"] },
                "연신내": { x: 2100, y: 1800, lines: ["3", "6"] },
                "경복궁": { x: 2300, y: 2000, lines: ["3"] },
                "약수": { x: 2900, y: 2500, lines: ["3", "6"] },
                "옥수": { x: 3000, y: 2800, lines: ["3", "K-J"] },
                "압구정": { x: 3200, y: 3000, lines: ["3"] },
                "양재": { x: 3100, y: 3700, lines: ["3", "S-X"] },
                "수서": { x: 3700, y: 4000, lines: ["3", "S-B"] },
                "오금": { x: 4100, y: 3700, lines: ["3", "5"], terminal: true },
                "진접": { x: 3800, y: 800, lines: ["4"], terminal: true },
                "이촌": { x: 2300, y: 3000, lines: ["4", "K-J"] },
                "동작": { x: 2500, y: 3100, lines: ["4", "9"] },
                "금정": { x: 1600, y: 4000, lines: ["1", "4"] },
                "안산": { x: 1300, y: 5000, lines: ["4"] },
                "오이도": { x: 1000, y: 5500, lines: ["4", "S-B"], terminal: true },
                "방화": { x: 1000, y: 2200, lines: ["5"], terminal: true },
                "김포공항": { x: 1200, y: 2400, lines: ["5", "9"] },
                "여의도": { x: 1800, y: 3000, lines: ["5", "9"] },
                "공덕": { x: 2000, y: 2600, lines: ["5", "6", "K-J"] },
                "광화문": { x: 2400, y: 2000, lines: ["5"] },
                "군자": { x: 3600, y: 2200, lines: ["5", "7"] },
                "천호": { x: 3900, y: 2400, lines: ["5", "8"] },
                "강동": { x: 4100, y: 2500, lines: ["5"] },
                "하남검단산": { x: 4600, y: 2500, lines: ["5"], terminal: true },
                "디지털미디어시티": { x: 1600, y: 2100, lines: ["6", "K-J"] },
                "불광": { x: 2100, y: 1600, lines: ["3", "6"] },
                "합정": { x: 1700, y: 2500, lines: ["2", "6"] },
                "삼각지": { x: 2300, y: 2700, lines: ["4", "6"] },
                "태릉입구": { x: 3500, y: 1500, lines: ["6", "7"] },
                "상봉": { x: 3600, y: 1800, lines: ["7", "K-J"] },
                "별내": { x: 4000, y: 1200, lines: ["8"], terminal: true },
                "구리": { x: 3900, y: 1800, lines: ["8", "K-J"] },
                "가락시장": { x: 4000, y: 3500, lines: ["3", "8"] },
                "모란": { x: 4000, y: 4500, lines: ["8", "S-B"], terminal: true },
                "선정릉": { x: 3300, y: 3200, lines: ["9", "S-B"] },
                "석촌": { x: 3800, y: 3100, lines: ["8", "9"] },
                "복정": { x: 4000, y: 3800, lines: ["8", "S-B"] },
                "강남구청": { x: 3300, y: 2900, lines: ["7", "S-B"] },
                "판교": { x: 3300, y: 4400, lines: ["S-X"] },
                "정자": { x: 3300, y: 4700, lines: ["S-B", "S-X"] },
                "지평": { x: 5000, y: 2500, lines: ["K-J"], terminal: true },
                "문산": { x: 800, y: 1000, lines: ["K-J"], terminal: true }
            }
        };

        const canvas = document.getElementById('canvas');
        const viewport = document.getElementById('viewport');
        const svgLayer = document.getElementById('svg-layer');
        let scale = 0.45;
        let posX = 0, posY = 0;
        let isDragging = false;
        let lastX, lastY;

        function updateTransform() {
            canvas.style.transform = `translate(${posX}px, ${posY}px) scale(${scale})`;
        }

        function handleZoom(delta, clientX, clientY) {
            const zoomFactor = delta > 0 ? 1.1 : 0.9;
            const newScale = Math.max(0.1, Math.min(3, scale * zoomFactor));
            const rect = viewport.getBoundingClientRect();
            const mouseX = clientX - rect.left;
            const mouseY = clientY - rect.top;
            const canvasX = (mouseX - posX) / scale;
            const canvasY = (mouseY - posY) / scale;
            scale = newScale;
            posX = mouseX - canvasX * scale;
            posY = mouseY - canvasY * scale;
            updateTransform();
        }

        // 로컬 데이터를 사용하여 AI 느낌의 응답 생성
        function fetchStationInfoOffline(stationName) {
            const loading = document.getElementById('loading-spinner');
            const responseText = document.getElementById('ai-response');
            
            loading.classList.remove('hidden');
            loading.classList.add('flex');
            responseText.innerHTML = "";
            
            // 데이터 베이스에 있는지 확인
            const data = stationGuides[stationName] || {
                desc: `${stationName}역은 수도권 전철망의 주요 지점 중 하나로, 주변 주민들에게 편리한 교통편을 제공합니다.`,
                spots: ["역 주변 상가", "인근 근린공원", "로컬 맛집"]
            };

            // 가짜 딜레이 (AI 느낌)
            setTimeout(() => {
                loading.classList.add('hidden');
                loading.classList.remove('flex');
                
                let html = `<h3>🌟 역 특징</h3><p>${data.desc}</p>`;
                html += `<h3>📍 가볼만한 곳</h3><ul>`;
                data.spots.forEach(spot => {
                    html += `<li>${spot}</li>`;
                });
                html += `</ul>`;
                html += `<div class="mt-8 p-4 bg-blue-500/10 border border-blue-500/20 rounded-xl text-[12px] text-blue-400">오프라인 모드로 정보를 표시 중입니다.</div>`;
                
                responseText.innerHTML = html;
            }, 800);
        }

        function init() {
            const legend = document.getElementById('legend');
            legend.innerHTML = '';

            Object.keys(subwayData.lines).forEach(id => {
                const line = subwayData.lines[id];
                const points = line.sequence
                    .map(name => subwayData.stations[name] ? `${subwayData.stations[name].x},${subwayData.stations[name].y}` : null)
                    .filter(p => p !== null);

                if (points.length > 1) {
                    const poly = document.createElementNS("http://www.w3.org/2000/svg", "polyline");
                    poly.setAttribute("points", points.join(" "));
                    poly.setAttribute("class", "subway-path");
                    poly.setAttribute("stroke", line.color);
                    poly.id = `path-${id}`;
                    svgLayer.appendChild(poly);

                    const item = document.createElement('div');
                    item.className = 'flex items-center gap-2 cursor-pointer hover:opacity-70 transition-opacity';
                    item.innerHTML = `<span class="w-4 h-1.5 rounded-full" style="background:${line.color}"></span><span class="font-bold text-slate-300">${line.name}</span>`;
                    item.onclick = () => highlightLine(id);
                    legend.appendChild(item);
                }
            });

            Object.keys(subwayData.stations).forEach(name => {
                const st = subwayData.stations[name];
                const div = document.createElement('div');
                div.className = `station ${st.lines.length > 1 ? 'transfer' : ''} ${st.terminal ? 'terminal' : ''}`;
                div.style.left = `${st.x}px`; div.style.top = `${st.y}px`;
                div.innerHTML = `<div class="station-label">${name}</div>`;
                div.onclick = (e) => { e.stopPropagation(); selectStation(name, st, div); };
                canvas.appendChild(div);
            });

            setupSearch();
            centerOnPoint(2500, 2500);
        }

        function highlightLine(id) {
            document.querySelectorAll('.subway-path').forEach(p => p.style.opacity = '0.1');
            const target = document.getElementById(`path-${id}`);
            if(target) target.style.opacity = '1';
            setTimeout(() => {
                document.querySelectorAll('.subway-path').forEach(p => p.style.opacity = '0.8');
            }, 2000);
        }

        function centerOnPoint(x, y) {
            posX = (viewport.clientWidth / 2) - (x * scale);
            posY = (viewport.clientHeight / 2) - (y * scale);
            updateTransform();
        }

        function selectStation(name, data, el) {
            document.querySelectorAll('.station').forEach(s => s.classList.remove('active'));
            if(el) el.classList.add('active');

            const sidebar = document.getElementById('sidebar');
            if (sidebar.classList.contains('collapsed')) toggleSidebar();

            document.getElementById('welcome-view').classList.add('hidden');
            document.getElementById('detail-view').classList.remove('hidden');
            document.getElementById('st-name').innerText = name + (data.terminal ? '역 (종점)' : '역');
            
            const badges = document.getElementById('line-badges');
            badges.innerHTML = '';
            data.lines.forEach(l => {
                const s = document.createElement('span');
                s.className = 'line-badge';
                s.style.background = subwayData.lines[l]?.color || '#444';
                s.innerText = subwayData.lines[l]?.name || l;
                badges.appendChild(s);
            });

            fetchStationInfoOffline(name);
        }

        function setupSearch() {
            const input = document.getElementById('station-search');
            const res = document.getElementById('search-results');
            input.oninput = () => {
                const q = input.value.trim().toLowerCase();
                if(!q) { res.classList.add('hidden'); return; }
                const found = Object.keys(subwayData.stations).filter(n => n.includes(q));
                if(found.length) {
                    res.innerHTML = found.map(n => `<div class="p-4 hover:bg-slate-700 cursor-pointer border-b border-slate-700 font-bold" onclick="selectFromSearch('${n}')">${n}</div>`).join('');
                    res.classList.remove('hidden');
                } else res.classList.add('hidden');
            };
        }

        window.selectFromSearch = (name) => {
            const st = subwayData.stations[name];
            document.getElementById('search-results').classList.add('hidden');
            centerOnPoint(st.x, st.y);
            // 라벨을 통해 실제 DOM 요소를 찾아 강조 표시
            const stations = Array.from(document.querySelectorAll('.station'));
            const target = stations.find(s => s.innerText.trim() === name);
            selectStation(name, st, target);
        };

        function closeDetail() {
            document.getElementById('detail-view').classList.add('hidden');
            document.getElementById('welcome-view').classList.remove('hidden');
            document.querySelectorAll('.station').forEach(s => s.classList.remove('active'));
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const icon = document.getElementById('toggle-icon');
            sidebar.classList.toggle('collapsed');
            icon.innerText = sidebar.classList.contains('collapsed') ? '◀' : '➔';
        }

        // 드래그 및 줌 이벤트
        viewport.onwheel = (e) => { e.preventDefault(); handleZoom(e.deltaY < 0 ? 1 : -1, e.clientX, e.clientY); };
        viewport.onmousedown = (e) => { if(e.button === 0) { isDragging = true; lastX = e.clientX; lastY = e.clientY; viewport.style.cursor = 'grabbing'; } };
        window.onmousemove = (e) => { if(isDragging) { posX += e.clientX - lastX; posY += e.clientY - lastY; lastX = e.clientX; lastY = e.clientY; updateTransform(); } };
        window.onmouseup = () => { isDragging = false; viewport.style.cursor = 'grab'; };

        // 터치 지원
        viewport.ontouchstart = (e) => { if(e.touches.length === 1) { isDragging = true; lastX = e.touches[0].clientX; lastY = e.touches[0].clientY; } };
        viewport.ontouchmove = (e) => { 
            if(isDragging && e.touches.length === 1) { 
                posX += e.touches[0].clientX - lastX; 
                posY += e.touches[0].clientY - lastY; 
                lastX = e.touches[0].clientX; 
                lastY = e.touches[0].clientY; 
                updateTransform(); 
            } 
        };
        viewport.ontouchend = () => { isDragging = false; };

        document.getElementById('zoom-in').onclick = () => handleZoom(1, viewport.clientWidth/2, viewport.clientHeight/2);
        document.getElementById('zoom-out').onclick = () => handleZoom(-1, viewport.clientWidth/2, viewport.clientHeight/2);
        document.getElementById('zoom-reset').onclick = () => { scale = 0.45; centerOnPoint(2500, 2500); };

        window.onload = init;
    </script>
</body>
</html>
